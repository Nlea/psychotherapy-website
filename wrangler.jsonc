{
  "main": "dist/_worker.js/index.js",
  "name": "manuel-website",
  "compatibility_date": "2026-02-06",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "routes": [
    { "pattern": "manuelmennig.de", "custom_domain": true },
    { "pattern": "www.manuelmennig.de", "custom_domain": true },
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
  },
  "observability": {
    "enabled": true,
  },
}
