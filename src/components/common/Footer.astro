<footer class="footer">
    <div class="footer-inner">
        <a href="/" class="footer-brand">Dr. Manuel Mennig</a>
        <p class="footer-copy">&copy; 2026 Dr. Manuel Mennig. Alle Rechte vorbehalten.</p>
        <div class="footer-links">
            <a href="/impressum">Impressum</a>
            <a href="/datenschutz">Datenschutz</a>
        </div>
    </div>
</footer>

<style>
    .footer {
        padding: var(--sp-12) var(--sp-6);
        background: var(--background);
        border-top: 1px solid var(--border);
    }

    .footer-inner {
        max-width: 1152px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--sp-6);
    }

    .footer-brand {
        font-family: var(--font-serif);
        font-size: 1.125rem;
        color: var(--foreground);
        text-decoration: none;
    }

    .footer-copy {
        font-size: 0.875rem;
        color: var(--muted-foreground);
    }

    .footer-links {
        display: flex;
        gap: var(--sp-6);
    }

    .footer-links a {
        font-size: 0.875rem;
        color: var(--muted-foreground);
        text-decoration: none;
    }

    .footer-links a:hover {
        color: var(--foreground);
    }

    @media (max-width: 767px) {
        .footer-inner {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
