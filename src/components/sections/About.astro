---
 interface Props {                                                                                                                                                
    ctaText?: string;
    ctaHref?: string; 
    sectionTitle: string;
    sectionDescription: string;
    sectionPoints:{title: string;
        text: string
    }[];
    sectionQualificationsWeiterbildungenList: string[];
    sectionQualificationsAusbildungList: string[];

  } 
const { ctaText = "Vollständige Vita", ctaHref = "/vita", sectionTitle, sectionDescription, sectionPoints, sectionQualificationsWeiterbildungenList, sectionQualificationsAusbildungList } = Astro.props;
---
<section class="about" id="ueber-mich">
    <div class="container">
        <div class="about-intro">
            <p class="section-eyebrow">Über mich</p>
            <h2 class="section-title">{sectionTitle}</h2>
            <p>{sectionDescription}</p>
        </div>
        <div class="about-grid">
            <div class="about-photo">
                <div class="about-photo-inner">
                    <div class="about-photo-placeholder">
                    </div>
                </div>
            </div>
            <div class="about-points">                                                                                                          
                <div class="prose">                                                                                                             
                    {sectionPoints.map((point) => (                                                                                             
                        <p>                                                                                                                   
                            <strong>{point.title}:</strong> {point.text}
                        </p>
                    ))}
                </div>
            </div>
        </div>  
        <!-- Qualifications -->
        <div class="qual-grid">
            <div>
                <h3 class="qual-title">Ausbildung</h3>
                <ul class="qual-list">
                    {sectionQualificationsAusbildungList.map((qualification) => (
                        <li>{qualification}</li>
                    ))}
                </ul>
            </div>
            <div>
                <h3 class="qual-title">Weiterbildungen</h3>
                <ul class="qual-list">
                    {sectionQualificationsWeiterbildungenList.map((qualification) => (
                        <li>{qualification}</li>
                    ))}
                </ul>
            </div>
        </div>

        <div style="margin-top: 2.5rem;">
            <a href={ctaHref} class="btn">{ctaText}</a>
        </div>
    </div>
</section>

<style>
    .about-intro {
        margin-bottom: var(--sp-12);
        padding-bottom: var(--sp-8);
        border-bottom: 1px solid var(--border);
        text-align: center;
    }

        .section-eyebrow {
            text-align: center;
            font-size: 0.875rem;
            font-weight: 400;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }

        .section-title {
            margin-bottom: 1.5rem;
        }

        .prose {
            color: var(--muted-foreground);
            line-height: 1.75;
        }

        .prose p {
            margin-bottom: 1rem;
        }

        .prose p:last-child {
            margin-bottom: 0;
        }

        .about-grid {
            display: grid;
            gap: 2rem;
        }

        @media (min-width: 768px) {
            .about-grid {
                grid-template-columns: 1fr 1fr;
                gap: 4rem;
                align-items: center;
            }
        }

        .about-photo {
            position: relative;
        }

        .about-content {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .about-photo-inner {
            aspect-ratio: 1;
            background: var(--muted);
            overflow: hidden;
            border-radius: 50%;
            width: 100%;
            max-width: 400px;
            margin: 0 auto;
        }
        .qual-grid {
            margin-top: var(--sp-12);
            padding-top: var(--sp-8);
            border-top: 1px solid var(--border);
            display: grid;
            gap: var(--sp-8);
        }                                                                                                        
                                                                                                           
  @media (min-width: 768px) {                                                                              
    .qual-grid {                                                                                           
      grid-template-columns: 1fr 1fr;  /* zwei gleiche Spalten */                                          
    }                                                                                                      
  }
  
  .qual-title {
            margin-bottom: 1rem;
        }

        .qual-list {
            list-style: none;
            color: var(--muted-foreground);
        }

        .qual-list li {
            padding: 0.5rem 0;
            padding-left: 1rem;
            position: relative;
            line-height: 1.75;
        }

        .qual-list li::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0.9em;
            width: 4px;
            height: 4px;
            background: var(--accent);
            border-radius: 50%;
        }                                                                                                        
    
</style>