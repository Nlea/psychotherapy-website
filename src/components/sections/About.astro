---
interface Props {
    ctaText?: string;
    ctaHref?: string;
    aboutHeading: string;
    aboutDescription: string;
    aboutPoints: { title: string; text: string; }[];
    aboutEducationList: string[];
    aboutTrainingList: string[];
}

const { ctaText = "Vollständige Vita", ctaHref = "/vita", aboutHeading, aboutDescription, aboutPoints, aboutEducationList, aboutTrainingList } = Astro.props;
---
<section class="about" id="ueber-mich">
    <div class="container">
        <div class="about-intro">
            <p class="eyebrow">Über mich</p>
            <h2>{aboutHeading}</h2>
            <p>{aboutDescription}</p>
        </div>
        <div class="about-grid">
            <div class="about-photo">
                <div class="about-photo-inner">
                    <div class="about-photo-placeholder">
                    </div>
                </div>
            </div>
            <div class="about-points">                                                                                                          
                <div class="prose">                                                                                                             
                    {aboutPoints.map((point) => (                                                                                             
                        <p>                                                                                                                   
                            <strong>{point.title}:</strong> {point.text}
                        </p>
                    ))}
                </div>
            </div>
        </div>  
        <!-- Qualifications -->
        <div class="qual-grid">
            <div>
                <h3 class="qual-title">Ausbildung</h3>
                <ul class="qual-list">
                    {aboutEducationList.map((qualification) => (
                        <li>{qualification}</li>
                    ))}
                </ul>
                <a href={ctaHref} class="vita-link">
                    {ctaText}
                </a>
            </div>
            <div>
                <h3 class="qual-title">Weiterbildungen</h3>
                <ul class="qual-list qual-list--two-col">
                    {aboutTrainingList.map((qualification) => (
                        <li>{qualification}</li>
                    ))}
                </ul>
            </div>
        </div>
    </div>
</section>

<style>
    .about-intro {
        margin-bottom: var(--sp-12);
        padding-bottom: var(--sp-8);
        border-bottom: 1px solid var(--border);
        text-align: center;
    }

    .about-grid {
            display: grid;
            gap: var(--sp-8);
        }

        @media (min-width: 768px) {
            .about-grid {
                grid-template-columns: 1fr 1fr;
                gap: var(--sp-16);
                align-items: center;
            }
        }

    .about-photo {
        position: relative;
    }

    .about-photo-inner {
            aspect-ratio: 1;
            background: var(--muted);
            overflow: hidden;
            border-radius: 50%;
            width: 100%;
            max-width: 400px;
            margin: 0 auto;
        }
        .vita-link {
            display: inline-flex;
            align-items: center;
            margin-top: var(--sp-6);
            padding: var(--sp-3) var(--sp-5);
            font-size: var(--text-sm);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: inherit;
            text-decoration: none;
            transition: opacity 0.2s ease;
            background-color: var(--muted);
        }

        .vita-link:hover {
            opacity: 0.7;
        }

        .qual-grid {
            margin-top: var(--sp-12);
            padding-top: var(--sp-8);
            border-top: 1px solid var(--border);
            display: grid;
            gap: var(--sp-8);
        }

        @media (min-width: 768px) {
            .qual-grid {
                grid-template-columns: 1fr 2fr;
            }

            /* 5 rows = fits current 7 items (5 left, 2 right) */
            .qual-list--two-col {
                display: grid;
                grid-template-rows: repeat(5, auto);
                grid-auto-flow: column;
                gap: 0 var(--sp-8);
            }
        }
  
    .qual-title {
        margin-bottom: var(--sp-4);
    }

    .qual-list {
        list-style: none;
        color: var(--muted-foreground);
    }

    .qual-list li {
        padding: var(--sp-2) 0;
        padding-left: var(--sp-4);
        position: relative;
        line-height: 1.75;
    }

    .qual-list li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.9em;
        width: 4px;
        height: 4px;
        background: var(--accent);
        border-radius: 50%;
    }
</style>