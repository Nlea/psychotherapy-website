---
 interface Props {                                                                                        
    eyebrow: string;                                                                                         
    name: string;                                                                                          
    description: string;   
    ctaText?: string;
    ctaHref?: string;                                                                                                                                                                      
  } 
const { eyebrow, name, description, ctaText = "Termin vereinbaren", ctaHref = "#kontakt" } = Astro.props;
---
    <section class="hero">
        <div class="hero-content">
            <p class="hero-eyebrow">{eyebrow}</p>
            <h1 class="hero-title">{name}</h1>
            <p class="hero-description">{description}</p>
            <a href={ctaHref} class="btn">{ctaText}</a>
        </div>
    </section>

<style>
.hero {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-20) var(--sp-6);
    text-align: center;
}

.hero-content {
    max-width: 48rem;
}

.hero-eyebrow {
    font-size: 0.875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--muted-foreground);
    margin-bottom: var(--sp-6);
}

.hero-title {
    line-height: 1.1;
    margin-bottom: var(--sp-8);
    text-wrap: balance;
}

.hero-description {
    max-width: 36rem;
    margin: 0 auto var(--sp-10);
}

.hero-content {                                                                                          
    animation: reveal 0.6s ease-out;                                                                       
  }   
</style>