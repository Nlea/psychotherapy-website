---
interface Props {
    eyebrow: string;
    title: string;
    psychotherapie: {
        label: string;
        title: string;
        description: string;
        subsections: {
            title: string;
            text: string;
            note?: string;
        }[];
    };
    coaching: {
        label: string;
        title: string;
        description: string;
        items: {
            title: string;
            content: string;
        }[];
    };
    seminare: {
        label: string;
        title: string;
        description: string;
        ctaText: string;
        ctaHref: string;
    };
}

const { eyebrow, title, psychotherapie, coaching, seminare } = Astro.props;
---
<section class="section section-services" id="angebote">
    <div class="container">
        <p class="eyebrow">{eyebrow}</p>
        <h2>{title}</h2>

    <div class="bento-grid">
        <!-- Psychotherapie -->
        <div class="bento-card bento-card--large">
            <p class="eyebrow card-eyebrow">{psychotherapie.label}</p>
            <h3 class="card-title">{psychotherapie.title}</h3>
            <p class="card-text">{psychotherapie.description}</p>
            <div class="card-content">
                {psychotherapie.subsections.map((sub, index) => (
                    <div class={`subsection ${index > 0 ? 'subsection-secondary' : ''}`}>
                        <h4>{sub.title}</h4>
                        <p>{sub.text}</p>
                        {sub.note && <p class="subsection-note">{sub.note}</p>}
                    </div>
                ))}
            </div>
        </div>
        <!-- Coaching -->
        <div class="bento-card bento-card--small">
            <p class="eyebrow card-eyebrow">{coaching.label}</p>
            <h3 class="card-title">{coaching.title}</h3>
            <p>{coaching.description}</p>
            <div class="accordion">
                {coaching.items.map((item) => (
                    <div class="accordion-item">
                        <button class="accordion-btn">
                            {item.title}
                            <span class="accordion-icon">+</span>
                        </button>
                        <div class="accordion-body">
                            <p>{item.content}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
        <!-- Seminare -->
        <div class="bento-card bento-card--small-secondary">
            <p class="eyebrow card-eyebrow">{seminare.label}</p>
            <h3 class="card-title">{seminare.title}</h3>
            <p>{seminare.description}</p>
            <a href={seminare.ctaHref} class="cta-link">
                {seminare.ctaText}
                <span>→</span>
            </a>
        </div>
    </div>
    </div>
</section>

<style>
    .section-services{
        background-color: var(--secondary);
    }
/* Bento Grid */
.bento-grid {
    display: grid;
    gap: var(--sp-6);
}
@media (min-width: 768px) {
      .bento-grid {
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: auto auto;
      }
    }

    .bento-card {
      padding: 2rem;
      border: 1px solid var(--border);
      background-color: var(--card);
      display: flex;
      flex-direction: column;
    }

    @media (min-width: 768px) {
      .bento-card {
        padding: 2.5rem;
      }
    }

    .bento-card--large {
      grid-column: span 1;
      grid-row: span 1;
    }

    @media (min-width: 768px) {
      .bento-card--large {
        grid-column: span 2;
        grid-row: span 2;
      }
    }

    .bento-card--small-secondary {
        background-color: var(--muted);
    }
    .card-text {
        margin-bottom: var(--sp-6);
        border-bottom: 2px solid var(--border);
        padding-bottom: var(--sp-6);
    }
    .subsection {
      padding-top: var(--sp-4); 
      margin-bottom: var(--sp-6);
    }

    .subsection-secondary {
        border-top: 1px solid var(--border);
    }

    .subsection:last-child {
      margin-bottom: 0;
    }
    .subsection h4 {
      margin-bottom: var(--sp-3);
  }

  .subsection-note {
      margin-top: var(--sp-3);
      color: var(--accent);
  }
                                                             
  .cta-link {                                                                                             
      display: inline-flex;                                                                               
      align-items: center;                                                                                
      font-size: var(--text-sm);                                              
      text-transform: uppercase;
      letter-spacing: 0.15em;
      margin-top: auto;  /* drückt den Link nach unten in der Card */
      color: inherit;
      text-decoration: none;
      transition: opacity 0.2s ease;
  }

  .cta-link:hover {
      opacity: 0.7;
  }

  .cta-link span {
      margin-left: var(--sp-2);
  }



    .card-eyebrow {
        text-align: left;
    }
    .card-title {
        margin-bottom: var(--sp-4);
    }

      /* Accordion */
  .accordion {
      margin-top: auto;
  }

  .accordion-item {
      border-bottom: 1px solid var(--border);
  }

  .accordion-btn {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: var(--sp-3) 0;
      background: none;
      border: none;
      cursor: pointer;
      font-size: var(--text-sm);
      text-align: left;
      font-family: inherit;
  }

  .accordion-btn:hover {
      opacity: 0.7;
  }

  .accordion-icon {
      transition: transform 0.2s ease;
  }

  .accordion-body {
      display: none;  /* versteckt */
  }

  /* Wenn aktiv → Content zeigen */
  .accordion-item.active .accordion-body {
      display: block;
      padding-bottom: var(--sp-3);
      font-size: var(--text-sm);
  }

  .accordion-item.active .accordion-icon {
      transform: rotate(45deg);  /* + wird zu × */
  }
    
    
    </style>

<script>                                                                                                
    document.querySelectorAll('.accordion-btn').forEach(button => {                                       
      button.addEventListener('click', () => {                                                            
        const item = button.parentElement;                                                              
        if (!item) return;

        const isActive = item.classList.contains('active');

        // close all items
        document.querySelectorAll('.accordion-item').forEach(i => {
          i.classList.remove('active');
        });

        // when not active, open the item
        if (!isActive) {
          item.classList.add('active');
        }
      });
    });
  </script>