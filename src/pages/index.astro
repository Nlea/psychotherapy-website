import Services from '../components/sections/Services.astro';
import Contact from '../components/sections/Contact.astro';

const heroContent = {
    eyebrow: "Psychologischer Psychotherapeut",
    name: "Dr. Manuel Mennig",
    description: "Mein Ziel ist es, dass Sie sich emotional sicher und fachlich bestens aufgehoben fühlen, um Ihre eigene Handlungsfähigkeit nachhaltig zurückzugewinnen."
  };

const quoteContent = {
  quote: "Zwischen Reiz und Reaktion liegt ein Raum. In diesem Raum liegt unsere Macht, unsere Reaktion zu wählen. In unserer Reaktion liegen unser Wachstum und unsere Freiheit.",
  author: "Viktor Frankl"
};

const aboutContent = {
  aboutHeading: "Fundierte Begleitung · Strukturierte Ruhe · Wärme in der Begegnung",
  aboutDescription: "Ich werde oft als ein Mensch mit einer ruhigen, besonnenen Art wahrgenommen. Als Ruhepol in unseren Gesprächen biete ich Ihnen die nötige Stabilität, um auch schwierige Themen sicher anzugehen. Mir liegt viel daran, eine aufgeräumte Atmosphäre zu schaffen, in der wir die Komplexität Ihres Erlebens gemeinsam ordnen.",
  aboutPoints: [{
    title: "Analytisch und zugewandt",
    text: "Mein Denken ist naturwissenschaftlich geprägt, ohne den Raum für Ihre Emotionen zu verlieren. Mit dieser analytischen Klarheit unterstütze  ich Sie dabei, den roten Faden in Ihrer Geschichte zu finden und das „Große Ganze“ im Blick zu behalten."
  },
  {
    title: "Struktur und Leichtigkeit",
    text: "Ich schätze eine klare Linie im Prozess. Dabei bin ich überzeugt, dass menschliche Wärme und eine Prise Humor auch schwere Prozesse ein Stück weit leichter machen können."
  },{
    title: "Wissenschaft und Empathie",
    text: "Ich arbeite nach evidenzbasierten klinischen Standards. Diese Fachlichkeit ist für mich kein Widerspruch zu echtem Interesse – sie ist das sichere Fundament unserer Begegnung auf Augenhöhe"
