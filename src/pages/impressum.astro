<style>
  .legal-page {
    max-width: 1152px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-6);
  }

  .legal-page .legal-section,
  .legal-page > h1,
  .legal-page > p {
    max-width: 65ch;
  }

  .legal-page h1 {
    margin-bottom: var(--sp-8);
    text-align: left;
  }

  .legal-page .legal-section {
    margin-bottom: var(--sp-8);
  }

  .legal-page h3 {
    margin-bottom: var(--sp-3);
  }

  .legal-page p {
    margin-bottom: var(--sp-4);
  }

  .legal-page a {
    color: var(--accent);
    text-decoration: none;
  }

  .legal-page a:hover {
    text-decoration: underline;
  }
</style>
